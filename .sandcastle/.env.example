# AFK orchestrator configuration.
# Copy to .sandcastle/.env and fill in the values that apply to your setup.

# The feature branch the orchestrator picks issues from. Required.
# Example: FEATURE_BRANCH=feat-user-auth
FEATURE_BRANCH=

# Pi model identifier as it appears in your models.json. Required.
# Example: PI_MODEL=qwen-coder-local
PI_MODEL=qwen-coder-local

# Maximum agent iterations per run. Optional. Default: 6.
# Lower values fail faster on stuck issues; higher values give the model
# more chances to recover from confusion.
MAX_ITERATIONS=6

# Wall-clock timeout for the entire Sandcastle run, in seconds.
# Optional. Default: 1800 (30 minutes). Local-model runs can be slow.
RUN_TIMEOUT_SECONDS=1800

# GitHub authentication. Either set GH_TOKEN here, or rely on `gh auth login`
# having been run previously on the host.
# GH_TOKEN=
